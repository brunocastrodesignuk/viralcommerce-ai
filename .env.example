# ─── ViralCommerce AI — Environment Variables ─────────────────
# Copy to .env and fill in your values

# App
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,https://app.viralcommerce.ai

# Database
DATABASE_URL=postgresql+asyncpg://viralcommerce:password@localhost:5432/viralcommerce

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=viralcommerce
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# ── AI Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # Optional, for fallback
LLM_MODEL=claude-sonnet-4-6

# ── Ad Networks ──────────────────────────────────────────────
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_APP_ID=

# ── Supplier APIs ─────────────────────────────────────────────
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
CJ_DROPSHIPPING_API_KEY=

# ── Social Platform APIs ─────────────────────────────────────
YOUTUBE_API_KEY=

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=

# ── Viral Score Config ───────────────────────────────────────
VIRAL_SCORE_THRESHOLD=70.0
